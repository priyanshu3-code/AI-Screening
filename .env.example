# ============================================
# Resume Screener - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# For production, use a secure secret management system (AWS Secrets Manager, HashiCorp Vault, etc.)
#
# IMPORTANT: Never commit actual API keys or sensitive data to version control!
# Use this file as a template only.

# ============================================
# CRITICAL: HuggingFace API Configuration
# ============================================
# REQUIRED: You MUST set this for the application to start
# Get your API key from: https://huggingface.co/settings/tokens
# Generate a new token with read access to HuggingFace Inference API
HUGGINGFACE_API_KEY=your_hf_token_here

# HuggingFace API URL (usually doesn't need changing)
HUGGINGFACE_API_URL=https://router.huggingface.co/v1

# ============================================
# LLM Model Configuration
# ============================================
# These are the models used for different tasks
# Change only if you want to use different models

# Resume extraction and initial analysis
LLM_EXTRACTION_MODEL=mistralai/Mistral-7B-Instruct-v0.2
LLM_EXTRACTION_TIMEOUT_MS=30000
LLM_EXTRACTION_MAX_TOKENS=1024
LLM_EXTRACTION_TEMPERATURE=0.3

# Interview questions generation
LLM_INTERVIEW_MODEL=mistralai/Mistral-7B-Instruct-v0.2
LLM_INTERVIEW_TIMEOUT_MS=45000
LLM_INTERVIEW_MAX_TOKENS=2048
LLM_INTERVIEW_TEMPERATURE=0.5

# Recruiter summary generation
LLM_SUMMARY_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_SUMMARY_TIMEOUT_MS=15000
LLM_SUMMARY_MAX_TOKENS=512
LLM_SUMMARY_TEMPERATURE=0.3

# LLM Retry Configuration
# How many times to retry failed API calls
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_INITIAL_BACKOFF_MS=1000
LLM_RETRY_BACKOFF_MULTIPLIER=2

# ============================================
# Server Configuration
# ============================================
# Backend server port
SERVER_PORT=8080

# Server context path (usually /)
SERVER_SERVLET_CONTEXT_PATH=/

# API base URL for frontend to connect to
# Development: http://localhost:8080
# Production: https://api.yourdomain.com
API_BASE_URL=http://localhost:8080

# API request timeout in seconds
API_TIMEOUT_SECONDS=30

# ============================================
# File Upload Configuration
# ============================================
# Maximum file size in MB (1-100)
FILE_MAX_SIZE_MB=10

# Allowed file extensions (comma-separated)
FILE_ALLOWED_TYPES=pdf,txt,doc,docx

# Minimum characters required in resume
FILE_MIN_RESUME_CHARS=100

# ============================================
# Job Description Configuration
# ============================================
# Minimum characters in job description
JOB_DESCRIPTION_MIN_CHARS=50

# Maximum characters in job description
JOB_DESCRIPTION_MAX_CHARS=50000

# ============================================
# Session Management Configuration
# ============================================
# Session timeout in minutes (5-1440)
# How long before a session expires
SESSION_TIMEOUT_MINUTES=60

# Session cleanup interval in minutes (1-60)
# How often to clean up expired sessions
SESSION_CLEANUP_INTERVAL_MINUTES=60

# Maximum concurrent sessions allowed
SESSION_MAX_CONCURRENT=100

# ============================================
# Match Score Configuration
# ============================================
# Score threshold for interview path (0-100)
# Candidates with score >= this get interview route
SCORING_INTERVIEW_THRESHOLD=70

# Weights for score calculation (must sum to 1.0)
SCORING_WEIGHT_SKILLS=0.40
SCORING_WEIGHT_EXPERIENCE=0.30
SCORING_WEIGHT_TECH_STACK=0.20
SCORING_WEIGHT_EDUCATION=0.10

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins for CORS
# Development: http://localhost:4200
# Production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ============================================
# Logging Configuration
# ============================================
# Root logging level (TRACE, DEBUG, INFO, WARN, ERROR)
LOGGING_LEVEL_ROOT=INFO

# Application-specific logging level
LOGGING_LEVEL_APP=DEBUG

# ============================================
# Environment Profile
# ============================================
# Determines which application-{profile}.yml is loaded
# Options: dev, test, prod
#
# dev:  Local development with verbose logging
# test: Testing with minimal logging and fast timeouts
# prod: Production with security hardening
SPRING_PROFILES_ACTIVE=dev

# ============================================
# Optional: Feature Flags
# ============================================
# Enable metrics collection
ENABLE_METRICS=true

# Enable Swagger/OpenAPI documentation
ENABLE_SWAGGER=true

# Swagger base path
SWAGGER_BASE_PATH=/api/v1

# ============================================
# Production Deployment Notes
# ============================================
# When deploying to production:
#
# 1. Change SPRING_PROFILES_ACTIVE=prod
# 2. Set HUGGINGFACE_API_KEY to your production key
# 3. Update API_BASE_URL to your production domain
# 4. Update CORS_ALLOWED_ORIGINS to your frontend domain
# 5. Increase SESSION_MAX_CONCURRENT based on expected load
# 6. Set LOGGING_LEVEL_ROOT=WARN for better performance
# 7. Use a secret management system (don't commit .env file)
# 8. Ensure all required environment variables are set
#
# Example production .env:
# SPRING_PROFILES_ACTIVE=prod
# HUGGINGFACE_API_KEY=${AWS_SECRET_HUGGINGFACE_KEY}
# API_BASE_URL=https://api.resumescreener.com
# CORS_ALLOWED_ORIGINS=https://resumescreener.com
# SERVER_PORT=8080
# SESSION_MAX_CONCURRENT=1000
# LOGGING_LEVEL_ROOT=WARN
